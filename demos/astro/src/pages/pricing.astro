---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Pricing - OpenVila Astro Demo">
  <section>
    <h2>Pricing</h2>
    <p><strong>Starter</strong>: $9/month for one site and one Vila profile.</p>
    <p><strong>Growth</strong>: $29/month for three sites, action scripts, and owner notifications.</p>
    <p><strong>Pro</strong>: $79/month for unlimited sites and advanced workflow support.</p>
    <p>All plans include manual review mode for sensitive action execution.</p>
  </section>
</BaseLayout>
